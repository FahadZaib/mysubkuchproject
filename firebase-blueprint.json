{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product available in the store",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "specialPrice": { "type": "number" },
        "category": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" },
        "stock": { "type": "number" },
        "isFeatured": { "type": "boolean" },
        "isLatest": { "type": "boolean" },
        "isNewArrival": { "type": "boolean" }
      },
      "required": ["name", "price", "category", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "dispatched", "shipped", "delivered", "cancelled"] },
        "date": { "type": "string" }
      },
      "required": ["items", "total", "customerEmail", "status"]
    },
    "User": {
      "title": "User",
      "description": "A registered user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["name", "email", "role"]
    },
    "Category": {
      "title": "Category",
      "description": "A product category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "image": { "type": "string" },
        "icon": { "type": "string" }
      },
      "required": ["name"]
    },
    "TeamMember": {
      "title": "TeamMember",
      "description": "A team member",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["name", "role"]
    },
    "GalleryImage": {
      "title": "GalleryImage",
      "description": "An image in the gallery",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "url": { "type": "string" },
        "caption": { "type": "string" }
      },
      "required": ["url"]
    },
    "CarouselSlide": {
      "title": "CarouselSlide",
      "description": "A slide in the home carousel",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "image": { "type": "string" },
        "cta": { "type": "string" },
        "route": { "type": "string" }
      },
      "required": ["title", "image"]
    },
    "Banner": {
      "title": "Banner",
      "description": "Site banner settings",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "image": { "type": "string" },
        "cta": { "type": "string" },
        "tagline": { "type": "string" }
      }
    },
    "ContactQuery": {
      "title": "ContactQuery",
      "description": "A message from the contact form",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "date": { "type": "string" }
      },
      "required": ["name", "email", "message"]
    },
    "SiteSettings": {
      "title": "SiteSettings",
      "description": "Global site settings",
      "type": "object",
      "properties": {
        "showMegaSale": { "type": "boolean" },
        "showFlashSale": { "type": "boolean" }
      }
    }
  },
  "firestore": {
    "/products": { "schema": "Product", "description": "Collection of products" },
    "/orders": { "schema": "Order", "description": "Collection of orders" },
    "/users": { "schema": "User", "description": "Collection of users" },
    "/categories": { "schema": "Category", "description": "Collection of categories" },
    "/team": { "schema": "TeamMember", "description": "Collection of team members" },
    "/gallery": { "schema": "GalleryImage", "description": "Collection of gallery images" },
    "/slides": { "schema": "CarouselSlide", "description": "Collection of carousel slides" },
    "/queries": { "schema": "ContactQuery", "description": "Collection of contact queries" },
    "/site_config/banner": { "schema": "Banner", "description": "Site banner configuration" },
    "/site_config/settings": { "schema": "SiteSettings", "description": "Site global settings" }
  }
}
